# ─────────────────────────────────────────────
# Redis Cache Staleness Monitor — Environment
# Copy to .env and fill in real values
# ─────────────────────────────────────────────

# ── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── PostgreSQL / PGVector ────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=csm_user
POSTGRES_PASSWORD=csm_password
POSTGRES_DB=csm_db
DATABASE_URL=postgresql://csm_user:csm_password@localhost:5432/csm_db

# ── Anthropic ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...your-key-here...
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_MAX_TOKENS=300

# ── Slack ────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
SLACK_CHANNEL=#cache-alerts

# ── AWS (prod) ───────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_DEFAULT_REGION=us-east-1

# ── AWS (LocalStack override for dev) ────────
# Set to true to route AWS calls to LocalStack
USE_LOCALSTACK=true
AWS_ENDPOINT_URL=http://localhost:4566
LOCALSTACK_REGION=us-east-1

# ── DynamoDB Tables ──────────────────────────
DYNAMODB_REGISTRY_TABLE=CacheKeyRegistry
DYNAMODB_HISTORY_TABLE=StalenessHistory

# ── S3 ───────────────────────────────────────
S3_RUNBOOKS_BUCKET=csm-runbooks

# ── SQS ──────────────────────────────────────
SQS_ALERT_QUEUE_URL=http://localhost:4566/000000000000/csm-alerts

# ── App Settings ─────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
STALENESS_CHECK_INTERVAL_SECONDS=30
SLA_BREACH_MULTIPLIER=1.5
# Max chars of Redis value to sample for auto-tagging (PII safety)
AUTO_TAG_VALUE_MAX_CHARS=200
